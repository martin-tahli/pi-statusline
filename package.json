{
  "name": "@shvax/pi-statusline",
  "version": "0.3.1",
  "description": "Configurable single-line status footer for pi",
  "type": "module",
  "license": "MIT",
  "author": "Martin Tahli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/martin-tahli/pi-statusline.git"
  },
